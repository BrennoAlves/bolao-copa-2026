# The Odds API (cadastro gratuito em https://the-odds-api.com)
ODDS_API_KEY=sua_chave_aqui
# Esporte/competicao na The Odds API (ex.: soccer_fifa_world_cup, soccer_epl)
ODDS_SPORT_KEY=soccer_fifa_world_cup

# Site do bolao
BOLAO_BASE_URL=https://www.seu-bolao.exemplo
BOLAO_EMAIL=seu@email.com
BOLAO_PASSWORD=sua_senha
# UUID da subliga onde voce compete (pegue em GET /api/subleagues)
BOLAO_SUBLEAGUE=cole-o-id-da-sua-subliga
# Nome da subliga como aparece na aba de picks (cosmetico, vai nas mensagens)
BOLAO_SUBLEAGUE_NOME=Bolao
# Como o bot se acha na classificacao. Sem nada setado, usa o prefixo do e-mail.
# Setar BOLAO_USER_ID se voce troca de nome de exibicao; senao BOLAO_NOME basta.
BOLAO_USER_ID=
BOLAO_NOME=
# Membros da subliga separados por virgula. Filtra a liga quando o scraper raspa
# a classificacao inteira. Vazio = sem filtro.
BOLAO_MEMBROS=

# Backend Supabase do site (REST). O ref do projeto sai do painel ou do cookie.
SUPABASE_URL=https://SEU_REF.supabase.co/rest/v1

# Polymarket: mercado de campeao do torneio (default = edicao atual; ajuste pro seu)
POLYMARKET_SLUG=world-cup-winner
POLYMARKET_CAMPEAO=win the 2026 fifa world cup

# Notificacoes via daemon cc, no mesmo servidor (porta local 8765)
CC_API_URL=http://localhost:8765
CC_TOKEN=seu_token_do_cc_aqui
# Tag do projeto no payload da notificacao
BOLAO_PROJECT_TAG=bolao

# Comportamento do apostador
BOLAO_AMBIENTE=local
ESTRATEGIA_APOSTA=auto
JOGOS_PARA_MODO_FINAL=10
APOSTAR_INICIO_DIA=true
HORA_APOSTA_DIARIA=8
JANELA_APOSTA_DIA_HORAS=28
MAX_RETRIES=3
RETRY_INTERVAL_MINUTES=10
TIMEZONE=America/Sao_Paulo
USAR_HTTP_SCRAPE=true
# Correcao do volume de gols do mercado. <1.0 puxa o placar pra margem 1.
# Backtest indicou 0.90 como bom. 1.0 = neutro.
LAMBDA_FATOR=0.90

# Opcionais (deixe vazio pra desligar)
ANTHROPIC_API_KEY=
FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_COMP=WC
